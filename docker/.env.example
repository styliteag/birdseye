# --- NetBird API ------------------------------------------------------------
NB_URL=https://netbird.example.com
# Read-only token for the forwarder (events endpoint).
NB_API_KEY=nbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Admin token for the cleanup_ephemeral cron job (DELETE on /peers).
# Leave empty to disable the admin path (forwarder still works).
NB_ADMIN_API_KEY=nbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Forwarder --------------------------------------------------------------
POLL_INTERVAL=30
MAX_CATCHUP=200
OUTAGE_ALERT_MINUTES=10
BACKOFF_CAP_SECONDS=300

# Per-sink include filters. Comma-separated fnmatch globs over activity_code.
# Default: stdout/Mattermost see everything; email is curated to config changes.
STDOUT_INCLUDE=*
MATTERMOST_INCLUDE=*
EMAIL_INCLUDE=policy.*,user.*,setupkey.*,personalaccesstoken.*,account.*

# --- Mattermost (leave empty to disable) ------------------------------------
MATTERMOST_WEBHOOK_URL=
MATTERMOST_USERNAME=NetBird

# --- Email (EMAIL_MODE: off | immediate | digest) ---------------------------
EMAIL_MODE=off
EMAIL_DIGEST_MINUTES=15
SMTP_HOST=
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=netbird-audit@example.com
# Comma-separated recipients.
SMTP_TO=

# --- Cron (cron syntax; empty = disabled) -----------------------------------
CRON_CLEANUP_EPHEMERAL=*/15 * * * *
# Weekly NetBird volume backup. Empty = disabled. Default below: Sunday 03:00.
CRON_BACKUP_NETBIRD=0 3 * * 0

# --- Volume backup ----------------------------------------------------------
# Paths inside this container, comma-separated. Mount NetBird's named volumes
# read-only into the birdseye service (see docker-compose.yml) and list them
# here. Leave empty to disable the backup job.
BACKUP_PATHS=
# Passphrase for the 7z archive (AES256, filenames also encrypted).
# Store somewhere safe — without it the archive is unrecoverable.
BACKUP_ZIP_PASSWORD=
# Recipient(s) for the backup mail; falls back to SMTP_TO if empty.
BACKUP_EMAIL_TO=
# Hard cap (MB) on the attachment. If exceeded, an error mail is sent instead.
BACKUP_MAX_ATTACHMENT_MB=20
# Free-form tag that ends up in the mail subject and archive filename.
BACKUP_LABEL=prod

# --- Timezone ---------------------------------------------------------------
TZ=Europe/Berlin
